{
  "name": "voynich-analysis",
  "version": "1.0.0",
  "description": "AI-driven cryptanalysis & unified decryption of the 15th-century Voynich Manuscript using 5 competing theories with ensemble scoring.",
  "author": "tonielee31_ai via OpenClaw framework",
  "license": "MIT",
  "main": "index.js",
  "engines": {
    "node": ">=23.11.0"
  },
  "scripts": {
    "test": "node naibbe-generator.js && node dai-anchor-parser.js && node scribe-cluster-analyzer.js",
    "naibbe-gen": "node naibbe-generator.js",
    "dai-anchor": "node dai-anchor-parser.js",
    "scribe-analyze": "node scribe-cluster-analyzer.js",
    "naibbe-sim": "node naibbe-simulator.js",
    "translate": "node trilingual-translator.js",
    "rtl-parse": "node rtl-judeo-italian-parser.js",
    "decode": "node voynich-decoder.js",
    "decode-detail": "node voynich-decoder.js --detail",
    "decode-a": "node voynich-decoder.js --section=A --detail",
    "decode-b": "node voynich-decoder.js --section=B --detail",
    "decode-full": "node voynich-decoder.js --full --output=decoded-output.txt",
    "arrhythmic-parse": "node arrhythmic-cycle-parser.js",
    "stat-validate": "node statistical-language-validator.js",
    "nlp-analyze": "node nlp-structural-analyzer.js",
    "decode-v5": "node voynich-decoder-v5.js",
    "decode-v5-detail": "node voynich-decoder-v5.js --detail",
    "decode-v5-full": "node voynich-decoder-v5.js --full --output=decoded-output-v5.txt",
    "decode-v5-a": "node voynich-decoder-v5.js --section=A --detail",
    "decode-v5-b": "node voynich-decoder-v5.js --section=B --detail",
    "consensus": "node voynich-consensus-analyzer.js",
    "semantic-patterns": "node voynich-semantic-patterns.js"
  },
  "keywords": [
    "voynich-manuscript",
    "cryptanalysis",
    "decryption",
    "cipher",
    "naibbe",
    "medieval",
    "computational-linguistics"
